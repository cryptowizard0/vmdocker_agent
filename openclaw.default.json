{
  "agents": {
    "defaults": {
      "model": {
        "primary": "kimi-coding/k2p5"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "tools": {
      "allow": [
        "sessions_create",
        "session_status",
        "sessions_send",
        "sessions_delete",
        "gateway"
      ]
    }
  },
  "tools": {
    "sessions": {
      "visibility": "all"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "defaultAccount": "main",
      "streaming": "off"
    }
  }
}
